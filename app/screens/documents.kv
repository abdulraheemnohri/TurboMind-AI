#:import MDTextButton kivymd.uix.button.MDTextButton
#:import MDIconButton kivymd.uix.button.MDIconButton
#:import MDFlatButton kivymd.uix.button.MDFlatButton
#:import MDProgressBar kivymd.uix.progressbar.MDProgressBar

<DocumentItem>:
    orientation: 'horizontal'
    padding: dp(10)
    spacing: dp(10)
    size_hint_y: None
    height: dp(60)
    
    MDLabel:
        id: doc_name
        text: ''
        halign: 'left'
        font_style: 'Body1'
        size_hint_x: 0.6
    
    MDLabel:
        id: doc_info
        text: ''
        halign: 'left'
        font_style: 'Caption'
        theme_text_color: 'Secondary'
        size_hint_x: 0.3
    
    MDIconButton:
        id: action_button
        icon: "dots-vertical"
        theme_text_color: "Secondary"
        on_press: 
        size_hint_x: None
        width: dp(48)


<DocumentsScreen>:
    name: 'documents'
    
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)
        
        MDTopAppBar:
            title: "Document Intelligence"
            elevation: 4
            left_action_items: [["arrow-left", lambda x: root.on_back_button()]]
            right_action_items: [["magnify", lambda x: root.search_document(root.current_document)], ["delete", lambda x: root.clear_documents()]]
            
        # Status and progress
        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            spacing: dp(5)
            size_hint_y: None
            height: dp(60)
            
            MDBoxLayout:
                orientation: 'horizontal'
                spacing: dp(10)
                
                MDLabel:
                    id: status_label
                    text: "Ready"
                    halign: 'left'
                    font_style: 'Caption'
                    theme_text_color: "Secondary"
                
                MDLabel:
                    id: doc_count_label
                    text: "0 documents loaded"
                    halign: 'right'
                    font_style: 'Caption'
                    theme_text_color: "Secondary"
            
            MDProgressBar:
                id: progress_bar
                value: 0
                size_hint_y: None
                height: dp(4)
        
        # Document list area
        ScrollView:
            id: scroll_view
            bar_width: dp(5)
            bar_color: app.theme_cls.primary_palette[:4] + [0.5]
            bar_inactive_color: app.theme_cls.primary_palette[:4] + [0.2]
            scroll_type: ['bars', 'content']
            
            MDBoxLayout:
                id: document_list
                orientation: 'vertical'
                padding: dp(10)
                spacing: dp(10)
                size_hint_y: None
                height: max(self.minimum_height, root.height - dp(250))
                adaptive_height: True
        
        # Action buttons
        MDBoxLayout:
            orientation: 'horizontal'
            padding: dp(10)
            spacing: dp(10)
            size_hint_y: None
            height: dp(60)
            
            MDRaisedButton:
                text: "Import Document"
                icon: "upload"
                on_press: root.open_file_manager()
                size_hint_x: 0.48
                elevation: 2
                
            MDRaisedButton:
                text: "New Scan"
                icon: "camera"
                on_press: root.scan_document()
                size_hint_x: 0.48
                elevation: 2
